// ============ EXPENSE CRUD ============
function addExpense(key) {
  const month = state.months.find(m => m.key === key);
  if (!month) return;
  month.expenses.push({ date: '', description: '', category: 'Other', amount: '' });
  saveState();
  renderMonth(month);
}

function updateExpense(key, idx, field, value) {
  const month = state.months.find(m => m.key === key);
  if (!month || !month.expenses[idx]) return;
  month.expenses[idx][field] = field === 'amount' ? parseFloat(value) || 0 : value;
  saveState();
  renderMonth(month);
}

function deleteExpense(key, idx) {
  const month = state.months.find(m => m.key === key);
  if (!month) return;
  month.expenses.splice(idx, 1);
  saveState();
  renderMonth(month);
}

function updateOpening(key, value) {
  const month = state.months.find(m => m.key === key);
  if (!month) return;
  month.openingBalance = parseFloat(value) || 0;
  saveState();
  renderMonth(month);
}

// ============ ARCHIVE ============
function archiveMonth(key) {
  if (!confirm('Archive ' + getMonthLabel(key) + '? It will be moved to the Archive tab.')) return;
  const month = state.months.find(m => m.key === key);
  if (!month) return;

  const c = calcAll();
  const netMonthly = c.netAnnual / 12;
  const totalExpenses = month.expenses.reduce((s, e) => s + (parseFloat(e.amount) || 0), 0);
  const closing = month.openingBalance + netMonthly - totalExpenses;

  state.archive.push({
    ...JSON.parse(JSON.stringify(month)),
    closingBalance: closing, netPayIn: netMonthly, totalExpenses,
    archivedAt: new Date().toISOString()
  });

  const monthIdx = state.months.indexOf(month);
  if (monthIdx < state.months.length - 1) {
    state.months[monthIdx + 1].openingBalance = closing;
  }

  state.months = state.months.filter(m => m.key !== key);
  const el = document.getElementById('tab-month-' + key);
  if (el) el.remove();

  saveState();
  renderMonthNav();
  renderArchive();
  switchTab('archive');
}

let currentArchiveIdx = -1;

function renderArchive() {
  const container = document.getElementById('archiveList');
  if (state.archive.length === 0) {
    container.innerHTML = '<div class="empty-state"><div class="empty-state-icon">&#128451;</div><p>No archived months yet.<br>Archive a month from its budget tab.</p></div>';
