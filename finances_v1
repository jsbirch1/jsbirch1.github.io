      <span class="nav-icon">&#128451;</span> Archive
    </div>
  </div>

  <div class="sidebar-footer">
    <button class="btn-add-month" onclick="addMonth()">+ Add Month</button>
  </div>
</div>

<!-- MAIN -->
<div class="main">
  <div class="page-header" id="pageHeader">
    <h2>Income / Payslip</h2>
    <p>Auto-calculated from your gross salary</p>
  </div>

  <div class="content">
    <!-- PAYSLIP TAB -->
    <div class="tab-content active" id="tab-payslip">
      <div class="info-banner">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        Tax code 1078L &middot; NI threshold &pound;12,570 &middot; Pension 4% (band &pound;6,240&ndash;&pound;50,270)
      </div>

      <div class="salary-input-group">
        <label for="grossSalary">Annual Gross Salary:</label>
        <input type="text" id="grossSalary" value="60000" onchange="recalcPayslip()" style="text-align:right;">
        <label for="taxCode">Tax Code:</label>
        <input type="text" id="taxCode" value="1078L" onchange="recalcPayslip()" style="width:100px;">
        <button class="btn btn-primary btn-sm" onclick="recalcPayslip()">Recalculate</button>
      </div>

      <div class="summary-row" id="payslipSummary"></div>

      <div class="payslip-grid">
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Gross to Net Breakdown</div>
              <div class="card-subtitle">Monthly figures</div>
            </div>
          </div>
          <div id="payslipBreakdown"></div>
        </div>
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Annual Summary</div>
              <div class="card-subtitle">Full tax year overview</div>
            </div>
          </div>
          <div id="annualSummary"></div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Tax, NI &amp; Pension Calculation Detail</div>
            <div class="card-subtitle">Banded breakdown with annual and monthly figures</div>
          </div>
          <div class="view-toggle" id="detailViewToggle">
            <button class="view-toggle-btn active" onclick="setDetailView('monthly')">Monthly</button>
            <button class="view-toggle-btn" onclick="setDetailView('annual')">Annual</button>
          </div>
        </div>
        <div id="taxDetail"></div>
      </div>
    </div>

    <!-- ARCHIVE TAB -->
    <div class="tab-content" id="tab-archive">
      <div class="card">
        <div class="card-header"><div class="card-title">Archived Months</div></div>
        <div id="archiveList" class="archive-list">
          <div class="empty-state">
            <div class="empty-state-icon">&#128451;</div>
            <p>No archived months yet.<br>Archive a month from its budget tab.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL: Add month -->
<div class="modal-overlay" id="addMonthModal">
  <div class="modal">
    <h2>Add Budget Month</h2>
    <div style="margin-bottom:14px;">
      <label style="font-size:13px;color:var(--text-muted);display:block;margin-bottom:4px;font-weight:600;">Select Month</label>
      <select id="newMonthSelect" style="width:100%;"></select>
    </div>
    <div style="margin-bottom:14px;">
      <label style="font-size:13px;color:var(--text-muted);display:block;margin-bottom:4px;font-weight:600;">Opening Balance (&pound;)</label>
      <input type="number" id="newMonthBalance" value="0" style="width:100%;text-align:right;" step="0.01">
    </div>
    <div class="checkbox-row" id="copyExpensesRow" style="display:none;">
      <input type="checkbox" id="copyExpensesCheck" checked>
      <label for="copyExpensesCheck">Copy expenses from <strong id="copyFromLabel">previous month</strong></label>
    </div>
    <div class="modal-actions">
      <button class="btn" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="confirmAddMonth()">Add Month</button>
    </div>
  </div>
</div>

<!-- MODAL: View archive -->
<div class="modal-overlay" id="archiveViewModal">
  <div class="modal" style="min-width:600px;max-width:720px;max-height:80vh;overflow-y:auto;">
    <h2 id="archiveViewTitle">Archived Month</h2>
    <div id="archiveViewContent"></div>
    <div class="modal-actions">
      <button class="btn btn-danger" onclick="deleteArchive()">Delete</button>
      <button class="btn" onclick="closeArchiveView()">Close</button>
    </div>
  </div>
</div>

<script>
// ============ STATE ============
let state = {
  grossSalary: 60000,
  taxCode: '1078L',
  months: [],
  archive: [],
  activeTab: 'payslip'
};

let detailView = 'monthly'; // 'monthly' or 'annual'

const CATEGORIES = ['Housing','Utilities','Transport','Food','Insurance','Subscriptions','Savings','Other'];
const CAT_CLASSES = {Housing:'cat-housing',Utilities:'cat-utilities',Transport:'cat-transport',Food:'cat-food',Insurance:'cat-insurance',Subscriptions:'cat-subscriptions',Savings:'cat-savings',Other:'cat-other'};
const MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];

// ============ LOCAL STORAGE ============
function saveState() { localStorage.setItem('financeTracker', JSON.stringify(state)); }
function loadState() {
  const s = localStorage.getItem('financeTracker');
  if (s) { try { state = JSON.parse(s); } catch(e) {} }
}

// ============ TAX CALCULATIONS ============
function parseTaxCode(code) {
  const m = code.match(/^(\d+)([A-Z])$/i);
  if (!m) return { allowance: 12570, suffix: 'L' };
  return { allowance: parseInt(m[1]) * 10, suffix: m[2].toUpperCase() };
}

function calcPAYE(grossAnnual, taxCode) {
  const { allowance } = parseTaxCode(taxCode);
  const taxable = Math.max(0, grossAnnual - allowance);
  let tax = 0;
  const bands = [{ limit: 37700, rate: 0.20 }, { limit: Infinity, rate: 0.40 }];
  let remaining = taxable;
  const detail = [];
  for (const band of bands) {
    const inBand = Math.min(remaining, band.limit);
    if (inBand <= 0) break;
    const bandTax = inBand * band.rate;
    tax += bandTax;
    detail.push({ amount: inBand, rate: band.rate, tax: bandTax });
    remaining -= inBand;
  }
  return { annual: tax, monthly: tax / 12, detail, allowance, taxable };
}

function calcNI(grossAnnual) {
  const threshold = 12570;
  const upperLimit = threshold + 37700;
  const niable = Math.max(0, grossAnnual - threshold);
  let ni = 0;
  const detail = [];
  const band1 = Math.min(niable, 37700);
  if (band1 > 0) { const t = band1 * 0.08; ni += t; detail.push({ amount: band1, rate: 0.08, ni: t }); }
  const band2 = Math.max(0, grossAnnual - upperLimit);
  if (band2 > 0) { const t = band2 * 0.02; ni += t; detail.push({ amount: band2, rate: 0.02, ni: t }); }
  return { annual: ni, monthly: ni / 12, detail, threshold };
}

function calcPension(grossAnnual) {
  const lower = 6240, upper = 50270, rate = 0.04;
  const pensionable = Math.max(0, Math.min(grossAnnual, upper) - lower);
  const contribution = pensionable * rate;
  const grossedUp = contribution / 0.8;
  return { annual: contribution, monthly: contribution / 12, pensionable, grossedUp, grossedUpMonthly: grossedUp / 12, rate, lowerLimit: lower, upperLimit: upper };
}

function calcAll() {
  const gross = state.grossSalary;
  const paye = calcPAYE(gross, state.taxCode);
  const ni = calcNI(gross);
  const pension = calcPension(gross);
  const totalDeductions = paye.annual + ni.annual + pension.annual;
  const netAnnual = gross - totalDeductions;
  return { gross, paye, ni, pension, totalDeductions, netAnnual };
}

