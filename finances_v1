  document.getElementById('archiveViewContent').innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px;">
      <div class="summary-card"><div class="summary-label">Opening</div><div class="summary-value" style="font-size:16px;">${fmt(a.openingBalance)}</div></div>
      <div class="summary-card"><div class="summary-label">Net Pay In</div><div class="summary-value text-green" style="font-size:16px;">+${fmt(a.netPayIn)}</div></div>
      <div class="summary-card"><div class="summary-label">Closing</div><div class="summary-value ${a.closingBalance >= 0 ? 'text-green' : 'text-red'}" style="font-size:16px;">${fmtSigned(a.closingBalance)}</div></div>
    </div>
    <table>
      <thead><tr><th>Date</th><th>Description</th><th>Category</th><th class="right">Amount</th><th class="right">Running Bal.</th></tr></thead>
      <tbody>
        ${sorted.map(e => {
          running -= (parseFloat(e.amount) || 0);
          return `<tr><td>${e.date || '—'}</td><td>${e.description || '—'}</td>
            <td><span class="category-tag ${CAT_CLASSES[e.category] || 'cat-other'}">${e.category || 'Other'}</span></td>
            <td class="right">${fmt(parseFloat(e.amount) || 0)}</td>
            <td class="right ${running >= 0 ? 'positive' : 'negative'}">${fmtSigned(running)}</td></tr>`;
        }).join('')}
        <tr class="total-row"><td></td><td>Total Expenses</td><td></td><td class="right text-red">${fmt(a.totalExpenses)}</td><td></td></tr>
      </tbody>
    </table>
  `;
  document.getElementById('archiveViewModal').classList.add('open');
}

function closeArchiveView() { document.getElementById('archiveViewModal').classList.remove('open'); currentArchiveIdx = -1; }

function deleteArchive() {
  if (currentArchiveIdx < 0) return;
  if (!confirm('Permanently delete this archived month?')) return;
  state.archive.splice(currentArchiveIdx, 1);
  saveState();
  renderArchive();
  closeArchiveView();
}

function restoreArchive(idx) {
  const a = state.archive[idx];
  if (state.months.find(m => m.key === a.key)) { alert('A tab for ' + getMonthLabel(a.key) + ' already exists.'); return; }
  state.months.push({ key: a.key, openingBalance: a.openingBalance, expenses: a.expenses });
  state.months.sort((x, y) => x.key.localeCompare(y.key));
  state.archive.splice(idx, 1);
  saveState();
  renderMonthNav();
  renderArchive();
  switchTab('month-' + a.key);
}

// ============ TAB SWITCHING ============
function switchTab(tabId) {
  state.activeTab = tabId;

  document.querySelectorAll('.nav-item').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));

  const navEl = document.querySelector(`.nav-item[data-tab="${tabId}"]`);
  if (navEl) navEl.classList.add('active');

  const header = document.getElementById('pageHeader');

  if (tabId === 'payslip') {
    document.getElementById('tab-payslip').classList.add('active');
    header.innerHTML = '<h2>Income / Payslip</h2><p>Auto-calculated from your gross salary</p>';
  } else if (tabId === 'archive') {
    document.getElementById('tab-archive').classList.add('active');
    header.innerHTML = '<h2>Archive</h2><p>Previously completed months</p>';
    renderArchive();
  } else if (tabId.startsWith('month-')) {
    const key = tabId.replace('month-', '');
    const month = state.months.find(m => m.key === key);
    if (month) {
      renderMonth(month);
      document.getElementById('tab-month-' + key).classList.add('active');
      header.innerHTML = `<h2>${getMonthLabel(key)} Budget</h2><p>Track expenses and cashflow for the month</p>`;
    }
  }

  renderMonthNav();
  saveState();
}

// ============ INIT ============
function init() {
  loadState();
  document.getElementById('grossSalary').value = state.grossSalary;
  document.getElementById('taxCode').value = state.taxCode;
  renderPayslip();
  renderMonthNav();

  if (state.activeTab && state.activeTab !== 'payslip' && state.activeTab !== 'archive') {
    const key = state.activeTab.replace('month-', '');
    const month = state.months.find(m => m.key === key);
    if (month) renderMonth(month);
  }

  switchTab(state.activeTab || 'payslip');
}

init();
</script>
