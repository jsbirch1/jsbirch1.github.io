// ============ MONTH HELPERS ============
function getMonthKey(year, month) { return `${year}-${String(month+1).padStart(2,'0')}`; }
function getMonthLabel(key) { const [y, m] = key.split('-'); return MONTH_NAMES[parseInt(m)-1] + ' ' + y; }
function getShortMonthLabel(key) { const [y, m] = key.split('-'); return MONTH_NAMES[parseInt(m)-1].slice(0,3) + ' ' + y; }

function getLastMonth() {
  if (state.months.length > 0) return state.months[state.months.length - 1];
  return null;
}

function calcClosing(month) {
  const netPay = calcAll().netAnnual / 12;
  const totalExp = month.expenses.reduce((s, e) => s + (parseFloat(e.amount) || 0), 0);
  return month.openingBalance + netPay - totalExp;
}

// ============ ADD MONTH ============
function addMonth() {
  const sel = document.getElementById('newMonthSelect');
  sel.innerHTML = '';
  const now = new Date(2026, 3, 1);
  for (let i = 0; i < 24; i++) {
    const d = new Date(now.getFullYear(), now.getMonth() + i, 1);
    const key = getMonthKey(d.getFullYear(), d.getMonth());
    if (!state.months.find(m => m.key === key)) {
      const opt = document.createElement('option');
      opt.value = key;
      opt.textContent = getMonthLabel(key);
      sel.appendChild(opt);
    }
  }

  const last = getLastMonth();
  const prevClosing = last ? calcClosing(last) : 0;
  document.getElementById('newMonthBalance').value = prevClosing.toFixed(2);

  // Show copy option if there's a previous month with expenses
  const copyRow = document.getElementById('copyExpensesRow');
  if (last && last.expenses.length > 0) {
    copyRow.style.display = 'flex';
    document.getElementById('copyFromLabel').textContent = getMonthLabel(last.key);
    document.getElementById('copyExpensesCheck').checked = true;
  } else {
    copyRow.style.display = 'none';
  }

  document.getElementById('addMonthModal').classList.add('open');
}

function closeModal() { document.getElementById('addMonthModal').classList.remove('open'); }

function confirmAddMonth() {
  const key = document.getElementById('newMonthSelect').value;
  if (!key) return;
  const openingBalance = parseFloat(document.getElementById('newMonthBalance').value) || 0;

  let expenses = [];
  const last = getLastMonth();
  const copyCheck = document.getElementById('copyExpensesCheck');
  if (last && last.expenses.length > 0 && copyCheck.checked) {
    // Copy expenses but update dates to new month
    const [newY, newM] = key.split('-').map(Number);
    expenses = last.expenses.map(e => {
      let newDate = e.date || '';
      if (newDate) {
        // Keep the day, change month/year
        const day = newDate.split('-')[2] || '01';
        // Clamp day to max days in new month
        const maxDay = new Date(newY, newM, 0).getDate();
        const clampedDay = Math.min(parseInt(day), maxDay);
        newDate = `${newY}-${String(newM).padStart(2,'0')}-${String(clampedDay).padStart(2,'0')}`;
      }
      return { date: newDate, description: e.description, category: e.category, amount: e.amount };
    });
  }

  state.months.push({ key, openingBalance, expenses });
  state.months.sort((a, b) => a.key.localeCompare(b.key));
  saveState();
  closeModal();
  renderMonthNav();
  switchTab('month-' + key);
}

// ============ SIDEBAR NAV ============
