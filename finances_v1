    const div = document.createElement('div');
    div.className = 'nav-item' + (state.activeTab === 'month-' + m.key ? ' active' : '');
    div.setAttribute('data-tab', 'month-' + m.key);
    div.onclick = (e) => { if (!e.target.classList.contains('nav-close')) switchTab('month-' + m.key); };
    div.innerHTML = `<span class="nav-icon">&#128197;</span>${getShortMonthLabel(m.key)}<span class="nav-close" onclick="event.stopPropagation();removeMonth('${m.key}')">&times;</span>`;
    container.appendChild(div);
